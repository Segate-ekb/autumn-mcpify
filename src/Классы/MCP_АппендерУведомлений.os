// Аппендер logos для MCP-процесса: пишет каждое событие лога в stdout как
// JSON-RPC уведомление notifications/message (server -> client logging).
//
// Зачем: в MCP-процессе stdout занят протоколом. Штатный консольный аппендер
// печатал бы "ИНФОРМАЦИЯ - ..." и ломал JSON-RPC. Этот аппендер вместо текста
// выдаёт валидное MCP-уведомление, поэтому протокол цел, а клиент видит ход
// выполнения команды в реальном времени (стриминг). Навешивается на КОРНЕВОЙ
// логгер (rootLogger) через конфиг logos (см. MCP_Запуск) и автоматически
// применяется ко всем логгерам приложения.
//
// Контракт аппендера logos: ВывестиСобытие(СобытиеЛога), Закрыть().

#Использовать json
#Использовать logos

Перем _ПарсерJSON;
Перем _КартаУровней; // числовой уровень logos -> уровень MCP

&Желудь
Процедура ПриСозданииОбъекта()
	_ПарсерJSON = Новый ПарсерJSON();
	_КартаУровней = Новый Соответствие();
	_КартаУровней.Вставить(УровниЛога.Отладка,        "debug");
	_КартаУровней.Вставить(УровниЛога.Информация,     "info");
	_КартаУровней.Вставить(УровниЛога.Предупреждение, "warning");
	_КартаУровней.Вставить(УровниЛога.Ошибка,         "error");
	_КартаУровней.Вставить(УровниЛога.КритичнаяОшибка,"critical");
КонецПроцедуры

// Вызывается logos на каждое событие лога.
Процедура ВывестиСобытие(Знач СобытиеЛога) Экспорт

	Параметры = Новый Соответствие();
	Параметры.Вставить("level", MCPУровень(СобытиеЛога.ПолучитьУровень()));
	Параметры.Вставить("logger", СобытиеЛога.ПолучитьИмяЛога());
	Параметры.Вставить("data", СобытиеЛога.ПолучитьСообщение());

	Уведомление = Новый Соответствие();
	Уведомление.Вставить("jsonrpc", "2.0");
	Уведомление.Вставить("method", "notifications/message");
	Уведомление.Вставить("params", Параметры);

	Консоль.ВывестиСтроку(_ПарсерJSON.ЗаписатьJSON(Уведомление, Ложь));

КонецПроцедуры

Процедура Закрыть() Экспорт
КонецПроцедуры

// Часть контракта аппендера: установка свойств из конфигурации (не используется).
Процедура УстановитьСвойство(Знач ИмяСвойства, Знач Значение) Экспорт
КонецПроцедуры

#Область СлужебныеПроцедурыИФункции

Функция MCPУровень(Знач УровеньЧислом)
	Сопоставленный = _КартаУровней.Получить(УровеньЧислом);
	Возврат ?(Сопоставленный = Неопределено, "info", Сопоставленный);
КонецФункции

#КонецОбласти
