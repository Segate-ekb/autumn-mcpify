// Юнит-тесты конфигурации запуска (MCP_Конфигурация): zero-config соглашения + сеттеры.

#Использовать asserts
#Использовать "../src/internal"

&Тест
Процедура ТестДолжен_ВывестиЗначенияПоУмолчаниюИзСоглашений() Экспорт
	Конф = Новый MCP_Конфигурация();
	РабочийКаталог = ТекущийКаталог();

	Ожидаем.Что(Конф.РабочийКаталог()).Равно(РабочийКаталог);
	Ожидаем.Что(Конф.ТочкаВходаCLI()).Равно(ОбъединитьПути(РабочийКаталог, "src", "main.os"));
	Ожидаем.Что(Конф.КаталогЗадач()).Равно(ОбъединитьПути(РабочийКаталог, "build", ".mcp-tasks"));
	Ожидаем.Что(Конф.ПрефиксЛоггера()).Равно("");
КонецПроцедуры

&Тест
Процедура ТестДолжен_ПрименитьСеттеры() Экспорт
	Конф = Новый MCP_Конфигурация();
	Конф.УстановитьТочкаВходаCLI("app/cli.os");
	Конф.УстановитьПрефиксЛоггера("myapp");

	Ожидаем.Что(Конф.ТочкаВходаCLI()).Равно("app/cli.os");
	Ожидаем.Что(Конф.ПрефиксЛоггера()).Равно("myapp");
КонецПроцедуры

// Корень приложения = родитель oscript_modules, где установлена библиотека.
// Это позволяет точке входа CLI работать независимо от текущего каталога.
&Тест
Процедура ТестДолжен_ВычислитьКореньПриложения_ИзПутиВнутриOscriptModules() Экспорт
	Конф = Новый MCP_Конфигурация();
	Пакет = ОбъединитьПути("прил", "oscript_modules", "autumn-mcpify");
	ПутьВнутри = ОбъединитьПути(Пакет, "src", "internal");
	ПутьМодуля = ОбъединитьПути(ПутьВнутри, "Классы", "MCP_Конфигурация.os");

	Ожидаем.Что(Конф.КореньПриложенияИзПутиМодуля(ПутьМодуля)).Равно("прил");
КонецПроцедуры

// Запуск из исходников библиотеки (нет oscript_modules в пути) - корень не определяется.
&Тест
Процедура ТестДолжен_ВернутьПустойКорень_ЕслиМодульНеПодOscriptModules() Экспорт
	Конф = Новый MCP_Конфигурация();
	ПутьВнутри = ОбъединитьПути("репо", "src", "internal");
	ПутьМодуля = ОбъединитьПути(ПутьВнутри, "Классы", "MCP_Конфигурация.os");

	Ожидаем.Что(Конф.КореньПриложенияИзПутиМодуля(ПутьМодуля)).Равно("");
КонецПроцедуры
