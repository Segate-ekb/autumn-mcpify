// Буфер-аппендер logos: накапливает события лога в память.
//
// Используется для синхронного debug-вызова команды (debug=true): на время
// вызова навешивается на логгеры приложения на уровне Отладки, собирает отладочный
// лог, затем снимается, а собранное возвращается в результате инструмента
// (см. MCP_ИнструментКоманды.ВыполнитьСЗахватомЛога).
//
// В отличие от MCP_АппендерУведомлений (стрим в notifications), этот аппендер
// никуда не пишет stdout — поэтому отладочный поток не засоряет MCP-протокол и
// не дублируется в клиентский стрим. Экземпляр одноразовый (на один вызов).
//
// Контракт аппендера logos: ВывестиСобытие(СобытиеЛога), Закрыть(), УстановитьСвойство().

#Использовать logos

Перем _Буфер; // Массив строк

Процедура ПриСозданииОбъекта()
	_Буфер = Новый Массив();
КонецПроцедуры

Процедура ВывестиСобытие(Знач СобытиеЛога) Экспорт
	_Буфер.Добавить(СтрШаблон("%1 %2: %3",
		УровниЛога.НаименованиеУровня(СобытиеЛога.ПолучитьУровень()),
		СобытиеЛога.ПолучитьИмяЛога(),
		СобытиеЛога.ПолучитьСообщение()));
КонецПроцедуры

Процедура Закрыть() Экспорт
КонецПроцедуры

// Часть контракта аппендера (конфигурация из настроек) — здесь не используется.
Процедура УстановитьСвойство(Знач ИмяСвойства, Знач Значение) Экспорт
КонецПроцедуры

// Накопленный лог одной строкой.
Функция ПолучитьЛог() Экспорт
	Возврат СтрСоединить(_Буфер, Символы.ПС);
КонецФункции
