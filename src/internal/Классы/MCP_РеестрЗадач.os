// Реестр фоновых задач MCP-сервера.
//
// Длительные команды (маркер &MCPДлительная) исполняются не in-process, а
// отдельным дочерним процессом `oscript <точка входа CLI> <подкоманда> <флаги>`:
// stdio-цикл сервера не блокируется. Вывод процесса перенаправляется в файл
// лога; статус/результат/отмена забираются инструментами task_* (поллинг).
//
// Дочерний процесс самодостаточен: эффективные опции (с учётом сессионного кэша)
// реконструируются вызывающим в CLI-флаги (см. MCP_ИнструментКоманды), общая
// память не нужна.
//
// Пути (oscript, точка входа CLI, рабочий каталог, каталог задач) берутся из
// MCP_Конфигурация - так реестр универсален для любого приложения на autumn-cli.
//
// Это обычный объект (не &Желудь): единственный экземпляр создаётся реестром
// инструментов и передаётся всем инструментам команд и task_*.

#Использовать autumn
#Использовать 1commands

Перем _Конфигурация;
Перем _Задачи;       // taskId(Строка) -> Структура задачи
Перем _Счётчик;

Процедура ПриСозданииОбъекта(Конфигурация)
	_Конфигурация = Конфигурация;
	_Задачи = Новый Соответствие();
	_Счётчик = 0;
КонецПроцедуры

// Запустить длительную команду фоном.
//
// Параметры:
//   ИмяКоманды        - Строка - имя инструмента (для читаемого taskId/лога)
//   АргументыКоманды  - Массив - токены CLI после `oscript <точка входа>` (путь подкоманды + флаги)
//
// Возвращаемое значение:
//   Строка - taskId
//
Функция Запустить(Знач ИмяКоманды, Знач АргументыКоманды) Экспорт

	_Счётчик = _Счётчик + 1;
	ТаскИд = СтрШаблон("%1-%2", ИмяКоманды, _Счётчик);

	КаталогЗадачи = ОбъединитьПути(КаталогЗадач(), ТаскИд);
	СоздатьКаталог(КаталогЗадачи);
	ФайлЛога = ОбъединитьПути(КаталогЗадачи, "output.log");

	ОскриптПуть = _Конфигурация.ПутьOscript();
	Если НЕ ЗначениеЗаполнено(ОскриптПуть) Тогда
		ВызватьИсключение "Не найден oscript в PATH - фоновый запуск невозможен.";
	КонецЕсли;
	ТочкаВхода = _Конфигурация.ТочкаВходаCLI();

	ПолныеТокены = Новый Массив();
	ПолныеТокены.Добавить(ОскриптПуть);
	ПолныеТокены.Добавить(ТочкаВхода);
	Для Каждого Токен Из АргументыКоманды Цикл
		ПолныеТокены.Добавить(Токен);
	КонецЦикла;

	Враппер = НаписатьВраппер(КаталогЗадачи, ПолныеТокены, ФайлЛога);

	Процесс = СоздатьПроцесс(КоманднаяСтрокаЗапускаВраппера(Враппер), _Конфигурация.РабочийКаталог());
	Процесс.Запустить();

	Задача = Новый Структура();
	Задача.Вставить("ТаскИд", ТаскИд);
	Задача.Вставить("Имя", ИмяКоманды);
	Задача.Вставить("Процесс", Процесс);
	Задача.Вставить("ФайлЛога", ФайлЛога);
	Задача.Вставить("КоманднаяСтрока", СтрСоединить(ПолныеТокены, " "));
	_Задачи.Вставить(ТаскИд, Задача);

	Возврат ТаскИд;

КонецФункции

// Статус задачи.
//
// Возвращаемое значение:
//   Структура - {Найдена, Состояние("running"|"completed"|"failed"), КодВозврата, Имя, КоманднаяСтрока}
//
Функция Статус(Знач ТаскИд) Экспорт

	Задача = _Задачи.Получить(ТаскИд);
	Если Задача = Неопределено Тогда
		Возврат Новый Структура("Найдена", Ложь);
	КонецЕсли;

	Результат = Новый Структура();
	Результат.Вставить("Найдена", Истина);
	Результат.Вставить("Имя", Задача.Имя);
	Результат.Вставить("КоманднаяСтрока", Задача.КоманднаяСтрока);

	Если НЕ Задача.Процесс.Завершен Тогда
		Результат.Вставить("Состояние", "running");
		Результат.Вставить("КодВозврата", Неопределено);
	Иначе
		КодВозврата = Задача.Процесс.КодВозврата;
		Результат.Вставить("Состояние", ?(КодВозврата = 0, "completed", "failed"));
		Результат.Вставить("КодВозврата", КодВозврата);
	КонецЕсли;

	Возврат Результат;

КонецФункции

// Прочитать лог задачи (последние СтрокЛимит строк).
Функция Лог(Знач ТаскИд, Знач СтрокЛимит = 200) Экспорт

	Задача = _Задачи.Получить(ТаскИд);
	Если Задача = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Файл = Новый Файл(Задача.ФайлЛога);
	Если НЕ Файл.Существует() Тогда
		Возврат "";
	КонецЕсли;

	Содержимое = ПрочитатьСовместно(Задача.ФайлЛога);
	Если НЕ ЗначениеЗаполнено(Содержимое) Тогда
		Возврат "";
	КонецЕсли;

	Строки = СтрРазделить(Содержимое, Символы.ПС, Истина);
	Если Строки.Количество() <= СтрокЛимит Тогда
		Возврат Содержимое;
	КонецЕсли;

	Хвост = Новый Массив();
	НачальныйИндекс = Строки.Количество() - СтрокЛимит;
	Для Индекс = НачальныйИндекс По Строки.Количество() - 1 Цикл
		Хвост.Добавить(Строки[Индекс]);
	КонецЦикла;
	Возврат СтрШаблон("… (показаны последние %1 строк)%2%3", СтрокЛимит, Символы.ПС, СтрСоединить(Хвост, Символы.ПС));

КонецФункции

// Отменить задачу (завершить процесс).
//
// Возвращаемое значение:
//   Строка - "notfound" | "alreadyfinished" | "cancelled"
//
Функция Отменить(Знач ТаскИд) Экспорт

	Задача = _Задачи.Получить(ТаскИд);
	Если Задача = Неопределено Тогда
		Возврат "notfound";
	КонецЕсли;

	Если Задача.Процесс.Завершен Тогда
		Возврат "alreadyfinished";
	КонецЕсли;

	// Завершаем всё дерево: запущен cmd/sh-враппер, реальная работа - во внуке
	// (oscript). Простой Завершить() убил бы только враппер, осиротив внука.
	ЗавершитьДерево(Задача.Процесс.Идентификатор);
	Попытка
		Задача.Процесс.Завершить();
	Исключение
		// процесс мог уже завершиться при убийстве дерева
	КонецПопытки;
	Возврат "cancelled";

КонецФункции

#Область СлужебныеПроцедурыИФункции

// Читает файл лога СОВМЕСТНО: дочерний процесс держит его открытым на запись
// (cmd `>` лочит эксклюзивно), поэтому прямой ЧтениеТекста падает с IOException.
// type/cat открывают файл с разделяемым доступом; вывод захватываем 1commands.
Функция ПрочитатьСовместно(Знач Путь)
	Кмд = Новый Команда;
	Если ЭтоWindows() Тогда
		Кмд.УстановитьКоманду("cmd");
		Кмд.ДобавитьПараметр("/S");
		Кмд.ДобавитьПараметр("/C");
		Кмд.ДобавитьПараметр("type");
		Кмд.ДобавитьПараметр(Путь);
	Иначе
		Кмд.УстановитьКоманду("cat");
		Кмд.ДобавитьПараметр(Путь);
	КонецЕсли;
	Кмд.Исполнить();
	Возврат Кмд.ПолучитьВывод();
КонецФункции

// Завершить процесс и всех его потомков по PID родителя.
Процедура ЗавершитьДерево(Знач ПИД)
	Кмд = Новый Команда;
	Если ЭтоWindows() Тогда
		Кмд.УстановитьКоманду("taskkill");
		Кмд.ДобавитьПараметр("/PID");
		Кмд.ДобавитьПараметр(Строка(ПИД));
		Кмд.ДобавитьПараметр("/T");
		Кмд.ДобавитьПараметр("/F");
	Иначе
		Кмд.УстановитьКоманду("pkill");
		Кмд.ДобавитьПараметр("-TERM");
		Кмд.ДобавитьПараметр("-P");
		Кмд.ДобавитьПараметр(Строка(ПИД));
	КонецЕсли;
	Попытка
		Кмд.Исполнить();
	Исключение
		// taskkill/pkill могли не найти процесс - не критично
	КонецПопытки;
КонецПроцедуры

Функция КаталогЗадач()
	Результат = _Конфигурация.КаталогЗадач();
	Если НЕ Новый Файл(Результат).Существует() Тогда
		СоздатьКаталог(Результат);
	КонецЕсли;
	Возврат Результат;
КонецФункции

// Пишем shell-враппер: он перенаправляет вывод команды в файл лога.
// Враппер избавляет от ада экранирования вложенных кавычек в командной строке.
Функция НаписатьВраппер(Знач КаталогЗадачи, Знач Токены, Знач ФайлЛога)

	Если ЭтоWindows() Тогда
		Враппер = ОбъединитьПути(КаталогЗадачи, "run.cmd");
		Строки = Новый Массив();
		Строки.Добавить("@echo off");
		Строки.Добавить(СтрШаблон("%1 1> ""%2"" 2>&1", СоединитьТокены(Токены, """"), ФайлЛога));
		ЗаписатьФайл(Враппер, СтрСоединить(Строки, Символы.ВК + Символы.ПС));
	Иначе
		Враппер = ОбъединитьПути(КаталогЗадачи, "run.sh");
		Строки = Новый Массив();
		Строки.Добавить("#!/bin/sh");
		Строки.Добавить(СтрШаблон("%1 1> '%2' 2>&1", СоединитьТокены(Токены, "'"), ФайлЛога));
		ЗаписатьФайл(Враппер, СтрСоединить(Строки, Символы.ПС));
	КонецЕсли;

	Возврат Враппер;

КонецФункции

// Командная строка для запуска враппера (через интерпретатор оболочки).
Функция КоманднаяСтрокаЗапускаВраппера(Знач Враппер)
	Если ЭтоWindows() Тогда
		Возврат СтрШаблон("cmd /S /C ""%1""", Враппер);
	КонецЕсли;
	Возврат СтрШаблон("sh ""%1""", Враппер);
КонецФункции

Функция СоединитьТокены(Знач Токены, Знач Кавычка)
	Части = Новый Массив();
	Для Каждого Токен Из Токены Цикл
		Если СтрНайти(Токен, " ") > 0 Или СтрНайти(Токен, Кавычка) > 0 Тогда
			Части.Добавить(Кавычка + Токен + Кавычка);
		Иначе
			Части.Добавить(Токен);
		КонецЕсли;
	КонецЦикла;
	Возврат СтрСоединить(Части, " ");
КонецФункции

Процедура ЗаписатьФайл(Знач Путь, Знач Содержимое)
	Запись = Новый ЗаписьТекста(Путь, "utf-8");
	Запись.Записать(Содержимое);
	Запись.Закрыть();
КонецПроцедуры

Функция ЭтоWindows()
	Возврат СтрНачинаетсяС(Строка(Новый СистемнаяИнформация().ТипПлатформы), "Windows");
КонецФункции

#КонецОбласти
