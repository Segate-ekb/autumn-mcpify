// Тесты сессионного кэша опций (MCP_КэшОпций).

#Использовать asserts
#Использовать "../src/internal"

Перем юТест;

Функция ПолучитьСписокТестов(ЮнитТестирование) Экспорт
	юТест = ЮнитТестирование;
	Тесты = Новый Массив;
	Тесты.Добавить("ТестДолжен_ВернутьЗапомненноеЗначение");
	Тесты.Добавить("ТестДолжен_СообщитьОбОтсутствииКлюча");
	Тесты.Добавить("ТестДолжен_ПерезаписатьЗначение");
	Возврат Тесты;
КонецФункции

Процедура ТестДолжен_ВернутьЗапомненноеЗначение() Экспорт
	Кэш = Новый MCP_КэшОпций();
	Кэш.Запомнить("ibconnection", "/F./build/ib");
	Ожидаем.Что(Кэш.Содержит("ibconnection")).ЕстьИстина();
	Ожидаем.Что(Кэш.Получить("ibconnection")).Равно("/F./build/ib");
КонецПроцедуры

Процедура ТестДолжен_СообщитьОбОтсутствииКлюча() Экспорт
	Кэш = Новый MCP_КэшОпций();
	Ожидаем.Что(Кэш.Содержит("v8version")).ЕстьЛожь();
	Ожидаем.Что(Кэш.Получить("v8version")).ЕстьНеопределено();
КонецПроцедуры

Процедура ТестДолжен_ПерезаписатьЗначение() Экспорт
	Кэш = Новый MCP_КэшОпций();
	Кэш.Запомнить("v8version", "8.3.24");
	Кэш.Запомнить("v8version", "8.3.25");
	Ожидаем.Что(Кэш.Получить("v8version")).Равно("8.3.25");
КонецПроцедуры
