// Юнит-тесты конфигурации запуска (MCP_Конфигурация): zero-config соглашения + сеттеры.

#Использовать asserts
#Использовать "../src/internal"

&Тест
Процедура ТестДолжен_ВывестиЗначенияПоУмолчаниюИзСоглашений() Экспорт
	Конф = Новый MCP_Конфигурация();
	РабочийКаталог = ТекущийКаталог();

	Ожидаем.Что(Конф.РабочийКаталог()).Равно(РабочийКаталог);
	Ожидаем.Что(Конф.ТочкаВходаCLI()).Равно(ОбъединитьПути(РабочийКаталог, "src", "main.os"));
	// Каталог задач — в системном временном каталоге (не в проекте), не привязан к РабочийКаталог.
	Ожидаем.Что(Конф.КаталогЗадач()).Равно(ОбъединитьПути(КаталогВременныхФайлов(), "autumn-mcpify-tasks"));
	Ожидаем.Что(Конф.ПрефиксЛоггера()).Равно("");
КонецПроцедуры

&Тест
Процедура ТестДолжен_ПрименитьСеттеры() Экспорт
	Конф = Новый MCP_Конфигурация();
	Конф.УстановитьТочкаВходаCLI("app/cli.os");
	Конф.УстановитьПрефиксЛоггера("myapp");

	Ожидаем.Что(Конф.ТочкаВходаCLI()).Равно("app/cli.os");
	Ожидаем.Что(Конф.ПрефиксЛоггера()).Равно("myapp");
КонецПроцедуры

// Корень приложения = родитель oscript_modules, где установлена библиотека.
// Это позволяет точке входа CLI работать независимо от текущего каталога.
&Тест
Процедура ТестДолжен_ВычислитьКореньПриложения_ИзПутиВнутриOscriptModules() Экспорт
	Конф = Новый MCP_Конфигурация();
	Пакет = ОбъединитьПути("прил", "oscript_modules", "autumn-mcpify");
	ПутьВнутри = ОбъединитьПути(Пакет, "src", "internal");
	ПутьМодуля = ОбъединитьПути(ПутьВнутри, "Классы", "MCP_Конфигурация.os");

	Ожидаем.Что(Конф.КореньПриложенияИзПутиМодуля(ПутьМодуля)).Равно("прил");
КонецПроцедуры

// Запуск из исходников библиотеки (нет oscript_modules в пути) - корень не определяется.
&Тест
Процедура ТестДолжен_ВернутьПустойКорень_ЕслиМодульНеПодOscriptModules() Экспорт
	Конф = Новый MCP_Конфигурация();
	ПутьВнутри = ОбъединитьПути("репо", "src", "internal");
	ПутьМодуля = ОбъединитьПути(ПутьВнутри, "Классы", "MCP_Конфигурация.os");

	Ожидаем.Что(Конф.КореньПриложенияИзПутиМодуля(ПутьМодуля)).Равно("");
КонецПроцедуры

#Область РазрешениеТочкиВхода

&Тест
Процедура ТестДолжен_РазобратьExecutableИзOpmMetadata() Экспорт
	Конф = Новый MCP_Конфигурация();
	Текст = "<opm-metadata xmlns=""http://oscript.io/schemas/opm-metadata/1.0"">"
		+ "<name>x</name>"
		+ "<executable name=""vrunner"">src/main.os</executable>"
		+ "<executable name=""vrunner-mcp"">src/mcp.os</executable>"
		+ "</opm-metadata>";

	Список = Конф.ИсполняемыеИзОпмМетаданныхТекст(Текст);

	Ожидаем.Что(Список.Количество()).Равно(2);
	Ожидаем.Что(Список[0].Путь).Равно("src/main.os");
	Ожидаем.Что(Список[0].Имя).Равно("vrunner");
	Ожидаем.Что(Список[1].Путь).Равно("src/mcp.os");
	Ожидаем.Что(Список[1].Имя).Равно("vrunner-mcp");
КонецПроцедуры

&Тест
Процедура ТестДолжен_РазобратьExecutableИзPackagedef() Экспорт
	Конф = Новый MCP_Конфигурация();
	Текст = "Описание.Имя(""app"")" + Символы.ПС
		+ "  .ИсполняемыйФайл(""src/main.os"", ""vrunner"")" + Символы.ПС
		+ "  .ИсполняемыйФайл(""src/main.os"", ""vanessa-runner"")" + Символы.ПС
		+ "  .ИсполняемыйФайл(""src/mcp.os"", ""vrunner-mcp"");";

	Список = Конф.ИсполняемыеИзPackagedefТекст(Текст);

	Ожидаем.Что(Список.Количество()).Равно(3);
	Ожидаем.Что(Список[0].Путь).Равно("src/main.os");
	Ожидаем.Что(Список[0].Имя).Равно("vrunner");
	Ожидаем.Что(Список[2].Путь).Равно("src/mcp.os");
	Ожидаем.Что(Список[2].Имя).Равно("vrunner-mcp");
КонецПроцедуры

// Имя приложения необязательно: .ИсполняемыйФайл("путь") -> Имя = "".
&Тест
Процедура ТестДолжен_РазобратьPackagedef_БезИмениПриложения() Экспорт
	Конф = Новый MCP_Конфигурация();
	Текст = ".ИсполняемыйФайл(""src/cli.os"")";

	Список = Конф.ИсполняемыеИзPackagedefТекст(Текст);

	Ожидаем.Что(Список.Количество()).Равно(1);
	Ожидаем.Что(Список[0].Путь).Равно("src/cli.os");
	Ожидаем.Что(Список[0].Имя).Равно("");
КонецПроцедуры

// Несколько имён на один файл - норма (vrunner/vanessa-runner -> src/main.os): после
// исключения mcp-скрипта остаётся ОДИН различный файл -> он и есть точка входа.
&Тест
Процедура ТестДолжен_ВыбратьЕдинственныйExecutable_ИсключивСамMcp() Экспорт
	Конф = Новый MCP_Конфигурация();
	КаталогМанифеста = ОбъединитьПути(ТекущийКаталог(), "пакет");
	ПутьМцп = ОбъединитьПути(КаталогМанифеста, "src", "mcp.os");

	Исполняемые = Новый Массив();
	Исполняемые.Добавить(Новый Структура("Путь, Имя", "src/main.os", "vrunner"));
	Исполняемые.Добавить(Новый Структура("Путь, Имя", "src/main.os", "vanessa-runner"));
	Исполняемые.Добавить(Новый Структура("Путь, Имя", "src/mcp.os", "vrunner-mcp"));

	Результат = Конф.ЕдинственныйИсполняемыйНеСам(Исполняемые, КаталогМанифеста, ПутьМцп);

	Ожидаем.Что(Новый Файл(Результат).Имя).Равно("main.os");
КонецПроцедуры

// Два РАЗНЫХ не-mcp executable - неоднозначно -> "".
&Тест
Процедура ТестДолжен_ВернутьПусто_ЕслиНесколькоРазныхExecutable() Экспорт
	Конф = Новый MCP_Конфигурация();
	КаталогМанифеста = ОбъединитьПути(ТекущийКаталог(), "пакет");
	ПутьМцп = ОбъединитьПути(КаталогМанифеста, "src", "mcp.os");

	Исполняемые = Новый Массив();
	Исполняемые.Добавить(Новый Структура("Путь, Имя", "src/main.os", "a"));
	Исполняемые.Добавить(Новый Структура("Путь, Имя", "src/other.os", "b"));

	Ожидаем.Что(Конф.ЕдинственныйИсполняемыйНеСам(Исполняемые, КаталогМанифеста, ПутьМцп)).Равно("");
КонецПроцедуры

// Единственный executable - сам mcp -> исключаем -> "".
&Тест
Процедура ТестДолжен_ВернутьПусто_ЕслиЕдинственныйExecutableЭтоMcp() Экспорт
	Конф = Новый MCP_Конфигурация();
	КаталогМанифеста = ОбъединитьПути(ТекущийКаталог(), "пакет");
	ПутьМцп = ОбъединитьПути(КаталогМанифеста, "src", "mcp.os");

	Исполняемые = Новый Массив();
	Исполняемые.Добавить(Новый Структура("Путь, Имя", "src/mcp.os", "app-mcp"));

	Ожидаем.Что(Конф.ЕдинственныйИсполняемыйНеСам(Исполняемые, КаталогМанифеста, ПутьМцп)).Равно("");
КонецПроцедуры

// Сквозной тест: хэндшейк mcp-скрипта + opm-metadata.xml на диске -> точка входа = main.os.
&Тест
Процедура ТестДолжен_ОпределитьТочкуВходаИз_OpmMetadataНаДиске() Экспорт
	Корень = ОбъединитьПути(КаталогВременныхФайлов(), "autumn-mcpify-тест-opm");
	Если Новый Файл(Корень).Существует() Тогда
		УдалитьФайлы(Корень);
	КонецЕсли;
	СоздатьКаталог(ОбъединитьПути(Корень, "src"));

	ТекстXML = "<opm-metadata xmlns=""http://oscript.io/schemas/opm-metadata/1.0"">"
		+ "<executable name=""app"">src/main.os</executable>"
		+ "<executable name=""app-mcp"">src/mcp.os</executable>"
		+ "</opm-metadata>";
	Запись = Новый ЗаписьТекста(ОбъединитьПути(Корень, "opm-metadata.xml"), "utf-8");
	Запись.Записать(ТекстXML);
	Запись.Закрыть();

	Попытка
		Конф = Новый MCP_Конфигурация();
		Конф.УстановитьСценарийЗапуска(ОбъединитьПути(Корень, "src", "mcp.os"));

		Результат = Конф.ТочкаВходаCLI();

		Ожидаем.Что(Новый Файл(Результат).Имя).Равно("main.os");
	Исключение
		УдалитьФайлы(Корень);
		ВызватьИсключение;
	КонецПопытки;
	УдалитьФайлы(Корень);
КонецПроцедуры

// Без хэндшейка и без манифеста - прежнее соглашение: <РабочийКаталог>/src/main.os.
&Тест
Процедура ТестДолжен_ИспользоватьСоглашение_БезХэндшейкаИМанифеста() Экспорт
	Конф = Новый MCP_Конфигурация();
	РабочийКаталог = ТекущийКаталог();

	Ожидаем.Что(Конф.ТочкаВходаCLI()).Равно(ОбъединитьПути(РабочийКаталог, "src", "main.os"));
КонецПроцедуры

#КонецОбласти
